################################################################################
# Dunkin Voice Chat Assistant — Azure Local Edge Deployment Environment Template
#
# Copy this file to .env and fill in your values before deploying.
#   cp .env.template .env
#
# Sections:
#   1. Azure Subscription & Resource Group
#   2. Azure Local / AKS Arc Infrastructure
#   3. Azure Key Vault (secrets management)
#   4. Azure Container Registry
#   5. Azure OpenAI (cloud — kept for hybrid mode)
#   6. Application Configuration
#
# All values marked [REQUIRED] must be set. Values marked [OPTIONAL] have
# sensible defaults.  Commented-out values show the default.
################################################################################

# ==============================================================================
# 1. AZURE SUBSCRIPTION & RESOURCE GROUP
# ==============================================================================

# [REQUIRED] Azure subscription ID (GUID)
AZURE_SUBSCRIPTION_ID=

# [REQUIRED] Resource group for edge deployment resources
AZURE_RESOURCE_GROUP=

# [REQUIRED] Azure region / location (e.g., eastus, westus2)
AZURE_LOCATION=eastus

# [OPTIONAL] Azure tenant ID — only needed for service-principal or AzCLI auth
# AZURE_TENANT_ID=

# ==============================================================================
# 2. AZURE LOCAL / AKS ARC INFRASTRUCTURE
# ==============================================================================

# [REQUIRED] Name of the Azure Local cluster (Azure Stack HCI registered name)
AZURE_LOCAL_CLUSTER_NAME=

# [REQUIRED] Custom Location resource ID — maps Azure Local to an Azure region
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.ExtendedLocation/customLocations/<name>
AZURE_CUSTOM_LOCATION_ID=

# [REQUIRED] Logical network name for AKS Arc cluster networking (static IPs)
AZURE_LOGICAL_NETWORK_NAME=

# [OPTIONAL] Logical network resource group (defaults to AZURE_RESOURCE_GROUP)
# AZURE_LOGICAL_NETWORK_RG=

# [REQUIRED] AKS Arc cluster name
AKS_CLUSTER_NAME=dunkin-edge-aks

# [OPTIONAL] AKS Arc Kubernetes version
# AKS_KUBERNETES_VERSION=1.28

# [OPTIONAL] AKS Arc node pool VM size — must be available on your Azure Local hardware
# AKS_NODE_VM_SIZE=Standard_NC4as_T4_v3

# [OPTIONAL] AKS Arc node count
# AKS_NODE_COUNT=1

# [OPTIONAL] Control plane IP — static IP from logical network for K8s API server
# AKS_CONTROL_PLANE_IP=

# [OPTIONAL] Load balancer IP range — for MetalLB / service IPs
# AKS_LB_IP_RANGE_START=
# AKS_LB_IP_RANGE_END=

# ==============================================================================
# 3. AZURE KEY VAULT (secrets management)
# ==============================================================================

# [REQUIRED] Key Vault name — must be globally unique (3-24 chars, alphanumeric + hyphens)
AZURE_KEYVAULT_NAME=

# [OPTIONAL] Key Vault resource group (defaults to AZURE_RESOURCE_GROUP)
# AZURE_KEYVAULT_RG=

# [OPTIONAL] Key Vault SKU (standard or premium)
# AZURE_KEYVAULT_SKU=standard

# [OPTIONAL] Enable soft-delete (recommended for production)
# AZURE_KEYVAULT_SOFT_DELETE=true

# [OPTIONAL] Managed identity name for AKS to access Key Vault
# Used by the Secrets Store CSI Driver to pull secrets from Key Vault
# AKS_MANAGED_IDENTITY_NAME=dunkin-edge-identity

# ==============================================================================
# 4. AZURE CONTAINER REGISTRY
# ==============================================================================

# [REQUIRED] ACR name — must be globally unique (5-50 chars, alphanumeric only)
AZURE_ACR_NAME=

# [OPTIONAL] ACR resource group (defaults to AZURE_RESOURCE_GROUP)
# AZURE_ACR_RG=

# [OPTIONAL] ACR SKU (Basic, Standard, Premium)
# AZURE_ACR_SKU=Standard

# [OPTIONAL] Docker image name and tag
DOCKER_IMAGE_NAME=dunkin-voice-assistant
DOCKER_IMAGE_TAG=latest

# ==============================================================================
# 5. AZURE OPENAI (cloud — hybrid mode)
# ==============================================================================
# The conversational LLM stays in Azure cloud for GPT-4o quality.
# These secrets will be stored in Key Vault and mounted via CSI driver.

# [REQUIRED] Azure OpenAI Realtime endpoint (WebSocket)
AZURE_OPENAI_EASTUS2_ENDPOINT=wss://<your-endpoint>.openai.azure.com

# [REQUIRED] Azure OpenAI API key
AZURE_OPENAI_EASTUS2_API_KEY=

# [OPTIONAL] Azure OpenAI deployment name
AZURE_OPENAI_REALTIME_DEPLOYMENT=gpt-realtime-mini

# [OPTIONAL] Azure OpenAI Realtime voice choice
AZURE_OPENAI_REALTIME_VOICE_CHOICE=coral

# ==============================================================================
# 6. APPLICATION CONFIGURATION
# ==============================================================================

# [OPTIONAL] Application host and port
# HOST=0.0.0.0
# PORT=8000

# [OPTIONAL] ChromaDB local vector store path (baked into container image)
# CHROMA_DATA_PATH=/app/chroma_data
# CHROMA_COLLECTION_NAME=menu_items

# [OPTIONAL] Kubernetes namespace for the application
# K8S_NAMESPACE=dunkin-voice
